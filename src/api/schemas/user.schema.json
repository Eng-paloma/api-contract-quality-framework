{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "required": ["id", "name", "email"],
  "properties": {
    "id": {"type": ["integer", "string"]},
    "name": {"type": "string"},
    "email": {"type": "string", "format": "email"},
    "phone": {"type": "string"},
    "website": {"type": "string"},
    "username": {"type": "string"},
    "company": {"type": "object"}
  },
  "additionalProperties": true
}
